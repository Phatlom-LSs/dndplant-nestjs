generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model userdata {
  id       Int    @id @default(autoincrement())
  username String @default("") @db.VarChar(255) @unique
  hashedpassword String
  createdAt DateTime @default(now())
  updateAt DateTime @updatedAt
  project Project[]
}

model Project {
  id        String    @id @default(uuid())
  name      String
  userId    Int
  user      userdata  @relation(fields: [userId], references: [id])
  layouts   Layout[]
  aldep     AldepRun[]
  createdAt DateTime  @default(now())
}

model Layout {
  id          String           @id @default(uuid())
  name        String
  gridSize    Int
  gridWidth     Int        @default(0)
  gridHeight    Int        @default(0)
  project     Project @relation(fields: [projectId], references: [id])
  projectId   String
  departments Department[]
  craftResults CraftResult[]
  corelapInput  Json?
  obstacles     Json?
  createdAt   DateTime         @default(now())
}

enum DepartmentType {
  DEPT
  VOID
}

model Department {
  id        String   @id @default(uuid())
  name      String
  x         Int?
  y         Int?
  width     Int?
  height    Int?
  type      DepartmentType @default(DEPT)
  locked    Boolean @default(false)
  layout    Layout   @relation(fields: [layoutId], references: [id])
  layoutId  String
}

model CraftResult {
  id          String   @id @default(uuid())
  layout      Layout   @relation(fields: [layoutId], references: [id])
  layoutId    String
  totalCost   Int
  totalDistance Int
  resultJson  Json
  createdAt   DateTime  @default(now())
}

model AldepRun {
  id             String   @id @default(uuid())
  project        Project  @relation(fields: [projectId], references: [id])
  projectId      String

  name           String
  gridWidth      Int
  gridHeight     Int

  lowerBound     String   @default("A")
  stripWidth     Int      @default(1)   // NEW: ความกว้างแถบ (คอลัมน์ต่อแถบ)
  seeds          Int      @default(8)
  cellSizeMeters Float?

  inputJson      Json
  resultJson     Json
  createdAt      DateTime @default(now())

  @@index([projectId, createdAt])
}
